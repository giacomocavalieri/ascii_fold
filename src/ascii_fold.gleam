/// Convert non-ascii characters into their ascii equivalent, if a
/// reasonable one exists.
///
/// For example accents are removed:
///
///```gleam
/// assert ascii_fold.fold("À") == "A"
/// ```
///
/// And composite characters are split into their composing letters:
///
/// ```gleam
/// assert ascii_fold.fold("⁇") == "??"
/// assert ascii_fold.fold("ᴁ") == "AE"
/// ```
///
pub fn fold(string: String) -> String {
  let splitter = splitter.new(special_characters)
  normalise_splitter_loop(splitter, string, "")
}

fn normalise_splitter_loop(
  splitter: splitter.Splitter,
  input: String,
  acc: String,
) -> String {
  case splitter.split(splitter, input) {
    #(rest, "", "") -> acc <> rest
    #(before, letter, rest) -> {
      let acc = acc <> before <> convert_letter(letter)
      normalise_splitter_loop(splitter, rest, acc)
    }
  }
}

