pub fn foldings_test() {
  list.each(test_cases, fn(pair) {
    let #(input, expected) = pair
    assert ascii_fold.fold(input) == expected
  })
}

pub fn not_folded_test() {
  assert ascii_fold.fold("§") == "§"
  assert ascii_fold.fold("¦") == "¦"
  assert ascii_fold.fold("¤") == "¤"
  assert ascii_fold.fold("END") == "END"
}
